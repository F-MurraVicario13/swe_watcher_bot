# Required
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Optional — data source
LISTINGS_URL=https://github.com/speedyapply/2027-SWE-College-Jobs
POLL_MINUTES=30
DB_PATH=seen.db
BOOTSTRAP_POST_LIMIT=3
INTERNSHIPS_ONLY=true
# Optional cutoff for old listings. Use ISO 8601 or Unix seconds.
# Leave blank to disable.
MIN_DATE_POSTED=

# Optional — filters (comma-separated, case-insensitive substring match)
# Only alert if the title contains one of these keywords.
TITLE_KEYWORDS=
# Only alert if a location contains one of these substrings.
LOCATIONS=
# Set to true to skip roles that require citizenship / explicitly offer no sponsorship.
SPONSORSHIP_ONLY=false
